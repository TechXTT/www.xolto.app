{
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run dev*)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run format*)",
      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npm run build 2>&1 | tail -40"
          }
        ]
      }
    ]
  },
  "ignore": [
    ".next",
    "node_modules",
    "*.tsbuildinfo"
  ]
}
