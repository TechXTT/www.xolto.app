# xolto landing frontend — Environment Variables
# Copy this file to .env.local and fill in real values.

# URL of the xolto app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL of this landing site (used for sitemap/robots/SEO metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Sentry client DSN for frontend monitoring
NEXT_PUBLIC_SENTRY_DSN=

# Optional local override for release identifier (defaults to Vercel commit SHA)
NEXT_PUBLIC_GIT_SHA=
